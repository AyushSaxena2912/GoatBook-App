{
  "expo": {
    "name": "GoatBook",
    "slug": "GoatBook",
    "version": "1.1.3",
    "sdkVersion": "54.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7A3A10"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "newArchEnabled": true
    },
    "android": {
      "package": "com.goatwala.farm",
      "versionCode": 5,
      "googleServicesFile": "./google-services.json",
      "newArchEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#7A3A10"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your farm profile and animals.",
          "cameraPermission": "The app accesses your camera to let you take photos of your livestock and profile."
        }
      ],
      "expo-notifications",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fbdd2a91-3947-442f-b555-79a7f85473d9"
      }
    },
    "owner": "ayush20001"
  }
}
